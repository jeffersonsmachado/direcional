// filepath: .vscode/tasks.json
{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "docker-compose up",
			"type": "shell",
			"command": "docker compose up -d sqlserver",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "docker-compose down",
			"type": "shell",
			"command": "docker compose down",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "build",
			"command": "dotnet",
			"type": "process",
			"args": [
				"build",
				"${workspaceFolder}/backend/Direcional.Api/Direcional.Api.csproj",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"dependsOn": "docker-compose up",
			"problemMatcher": "$msCompile"
		}
	]
}
